JWT_SECRET=
DATABASE_URL=sqlite:///./app.db

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:4b

# ComfyUI: local (z-image-turbo) or Colab/cloud tunnel (FLUX Kontext)
COMFY_BASE_URL=http://127.0.0.1:8188
COMFY_TIMEOUT_SECONDS=300
# WebSocket connect timeout (s). 10 is fine local; keep ≥30 for a cloud tunnel.
COMFY_WS_OPEN_TIMEOUT=30
# "zimage" — local 4GB VRAM, z-image-turbo (4-step, denoise-based edit)
# "flux_kontext" — cloud GPU ≥10GB, FLUX.1 Kontext Q3_K_S (instruction-edit)
COMFY_BACKEND=zimage
# Set BOTH only if the ComfyUI tunnel is behind Cloudflare Access (Zero Trust).
# Leave empty for a plain quick tunnel / local ComfyUI.
COMFY_CF_ACCESS_CLIENT_ID=
COMFY_CF_ACCESS_CLIENT_SECRET=
